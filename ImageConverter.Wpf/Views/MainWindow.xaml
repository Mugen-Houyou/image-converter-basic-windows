<Window x:Class="ImageConverter.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageConverter.Wpf.Views"
        xmlns:models="clr-namespace:ImageConverter.Core.Models;assembly=ImageConverter.Core"
        xmlns:conv="clr-namespace:ImageConverter.Wpf.Converters"
        Title="이미지 변환기"
        MinWidth="900" MinHeight="550"
        Width="960" Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:FilePathToBitmapConverter x:Key="PathToImage" />
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: 상단 버튼 바 -->
        <Border Grid.Row="0" Padding="4" Margin="0,0,0,6"
                Background="#F3F3F3" CornerRadius="4">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="파일 추가" Padding="8,4" MinWidth="70" Margin="0,0,6,0"
                            Command="{Binding AddFilesCommand}" />
                    <Button Content="변환 시작" Padding="8,4" MinWidth="70" Margin="0,0,6,0"
                            Command="{Binding StartConversionCommand}" />
                    <Button Content="목록 지우기" Padding="8,4" MinWidth="70" Margin="0,0,10,0"
                            Command="{Binding ClearFilesCommand}" />
                    <ComboBox ItemsSource="{Binding OutputFormatNames}"
                              SelectedItem="{Binding SelectedOutputFormatName}"
                              VerticalAlignment="Center" Margin="6,0,0,0" />
                    <Border Background="Transparent"
                            MouseRightButtonDown="WebpArea_MouseRightButtonDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding QualityText}" VerticalAlignment="Center"
                                       Width="64" TextAlignment="Right" Margin="4,0,6,0" />
                            <Slider Value="{Binding WebpQuality}" Minimum="0" Maximum="100"
                                    Width="100" VerticalAlignment="Center"
                                    SmallChange="1" LargeChange="10"
                                    IsMoveToPointEnabled="True"
                                    Opacity="{Binding SliderOpacity}" />
                        </StackPanel>
                    </Border>
                    <CheckBox Content="EXIF 제거" IsChecked="{Binding RemoveExif}"
                              VerticalAlignment="Center" Margin="10,0,0,0" />
                    <CheckBox Content="타깃 용량" IsChecked="{Binding IsTargetSizeEnabled}"
                              VerticalAlignment="Center" Margin="10,0,0,0" />
                    <TextBox Text="{Binding TargetSizeKb, Mode=TwoWay}" Width="56"
                             VerticalAlignment="Center" Margin="4,0,2,0"
                             Opacity="{Binding TargetSizeOpacity}" />
                    <TextBlock Text="KB" VerticalAlignment="Center"
                               Opacity="{Binding TargetSizeOpacity}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="로그 지우기" Padding="8,4" MinWidth="70"
                            Command="{Binding ClearLogCommand}" />
                    <Button Content="ℹ" Padding="6,2" MinWidth="30" Margin="6,0,0,0"
                            FontSize="14" ToolTip="About"
                            Click="AboutButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 좌우 패널 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: ListView + 안내 문구 -->
            <Grid Grid.Column="0">
                <!-- 파일 목록 -->
                <ListView x:Name="FileListView"
                          ItemsSource="{Binding Files}"
                          AllowDrop="True"
                          DragEnter="FileListView_DragEnter"
                          Drop="FileListView_Drop"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="파일명" Width="240">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ImageFileItem}">
                                        <TextBlock Text="{Binding FileName}"
                                                   ToolTipService.InitialShowDelay="300"
                                                   ToolTipService.BetweenShowDelay="200">
                                            <TextBlock.ToolTip>
                                                <Image Source="{Binding FilePath, Converter={StaticResource PathToImage}}"
                                                       MaxWidth="240" MaxHeight="240"
                                                       Stretch="Uniform" />
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="상태" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ImageFileItem}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" Width="20"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding StatusText}" />
                                            <ProgressBar IsIndeterminate="True" Width="60" Height="14"
                                                         Margin="6,0,0,0"
                                                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 빈 상태 안내 문구 -->
                <TextBlock x:Name="EmptyHint"
                           Text="여기에 파일을 끌어다 놓으세요&#x0a;또는 상단의 [파일 추가] 버튼을 클릭하세요"
                           FontSize="15" Foreground="#999999"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                           IsHitTestVisible="False" />
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#E0E0E0" />

            <!-- RIGHT: 로그 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="로그" FontWeight="Bold"
                           Margin="4,0,0,4" />
                <TextBox Grid.Row="1"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         TextWrapping="Wrap"
                         Background="#FAFAFA" />
            </Grid>
        </Grid>
    </Grid>
</Window>
